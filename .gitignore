# Virtual environment — never commit, recreate from requirements.txt
venv/

# Generated Delta tables — large binary data, derived from raw_data
delta_tables/

# Raw Excel Data will not be stored with this repo. Add in yourself after cloning.
raw_data/*
!raw_data/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# OS
.DS_Store

# IDE
.vscode/
.idea/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# AWS credentials — never commit the actual .env files (only .env.example is safe to commit)
.env.dev
.env.prod
.env.staging

# Next.js web app
web/.next/
web/node_modules/
web/.env.local

# Terraform — never commit state or secrets
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.backup
infra/**/terraform.tfvars
